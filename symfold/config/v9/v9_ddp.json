{
  "project_name": "prifold_symflow",
  "task_name": "v9_ddp",
  "device": "auto",

  "paths": {
    "data_dir": "/root/aigame/dannyyan/PriFold/data",
    "pretrained_lm_dir": "/root/aigame/dannyyan/PriFold/model",
    "log_dir": "/root/aigame/dannyyan/PriFold/symfold/logs/v9_ddp",
    "output_dir": "/root/aigame/dannyyan/PriFold/symfold/outputs/v9_ddp",
    "model_save_dir": "/root/aigame/dannyyan/PriFold/symfold/outputs/v9_ddp/model"
  },

  "model": {
    "version": "v9",
    "mars_scale": "lx",
    "freeze_mars": true,
    "mars_dim": 1056,
    "mars_n_attn_layers": 6,
    "mars_n_heads": 12,
    "mars_hidden_layer_indices": [3, 6, 9, 12],
    "dropout": 0.2
  },

  "v9": {
    "hidden_dim": 192,
    "num_layers": 8,
    "num_heads": 6,
    "dim_head": 32,
    "ff_mult": 4,
    "dropout": 0.2,
    "drop_path": 0.15,
    "use_rope": true
  },

  "loss": {
    "focal_gamma": 1.0,
    "pos_weight_base": 99.0,
    "dice_weight": 0.5,
    "dst_weight": 0.5,
    "dst_low_threshold": 0.05,
    "dst_tversky_alpha": 0.7,
    "dst_tversky_beta": 0.3,
    "pair_count_weight": 0.3,
    "ratio_penalty_weight": 0.2,
    "ratio_penalty_threshold": 1.20,
    "density_loss_weight": 0.3,
    "ohem_enabled": true,
    "ohem_neg_ratio": 3,
    "fp_penalty_enabled": true,
    "fp_penalty_weight": 2.0,
    "bp_compat_enabled": false,
    "bp_compat_weight": 0.0,
    "bp_compat_in_inference": false,
    "shift_loss_enabled": true,
    "shift_loss_weight": 0.8,
    "shift_radius": 2
  },

  "training": {
    "dataset_mode": "bprna",
    "batch_size": 12,
    "max_sq_tokens": 600000,
    "gradient_accumulation_steps": 2,
    "lr": 5e-4,
    "weight_decay": 0.02,
    "epochs": 200,
    "warmup_epochs": 8,
    "patience": 35,
    "save_every": 9999,
    "grad_clip": 1.0,
    "amp_dtype": "bf16",
    "max_len_filter": 490,
    "augmentation": {"enabled": true, "select": 0.20, "replace": 0.40},
    "family_balanced": {"enabled": false},
    "num_workers": 8,
    "pin_memory": true,
    "prefetch_factor": 4,
    "compile_model": false,
    "compile_mode": "default",
    "test_eval_every": 10,
    "ddp": {
      "enabled": true,
      "backend": "nccl",
      "find_unused_parameters": false
    }
  },

  "sampling": {
    "use_density_budget": true,
    "default_budget_fraction": 0.30,
    "score_threshold": 0.43,
    "length_decay": 0.15,
    "budget_floor": 0.6
  }
}
